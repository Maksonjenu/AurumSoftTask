<Window x:Class="AurumSoftTask.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AurumSoftTask.WPF.Views"
        
        xmlns:vm="clr-namespace:AurumSoftTask.WPF.ViewModels"
        
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        
        mc:Ignorable="d"
        Title="MainWindow" Height="520" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="23"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu>
            <MenuItem Header="File" Height="23">
                <MenuItem Header="Open" Command="{Binding LoadFileCommand}"/>
                <MenuItem Header="Save" Command="{Binding SaveFileCommand}"/>
            </MenuItem>
            <CheckBox Content="Use LLM normalization for rocks" IsChecked="{Binding UseLlmNormalization}"/>
        </Menu>


        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="5">
            <TextBlock Text="Valid data"/>
            <DataGrid ItemsSource="{Binding Summaries}"/>
        </StackPanel>


        <StackPanel Grid.Row="2" Margin="5">
            <TextBlock Text="Invalid data"/>
            <DataGrid ItemsSource="{Binding Errors}"/>
        </StackPanel>
        



    </Grid>
</Window>
