<Window x:Class="AurumSoftTask.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AurumSoftTask.WPF.Views"
        
        xmlns:vm="clr-namespace:AurumSoftTask.WPF.ViewModels"
        
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="400">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="20*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Menu Grid.ColumnSpan="3">
            <MenuItem Header="File">
                <MenuItem Header="Open" Command="{Binding LoadFileCommand}"/>
                <MenuItem Header="Save" />
                <MenuItem Header="Exit" />
            </MenuItem>
        </Menu>

        <DataGrid Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding Summaries}"/>
        <DataGrid Grid.Row="1" Grid.Column="2" ItemsSource="{Binding Errors}"/>



    </Grid>
</Window>
